# ============================================================
# Fintech MVP — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
#   cp .env.example .env
# NUNCA commite o arquivo .env com credenciais reais.
# ============================================================

# ── Banco de Dados (PostgreSQL) ──────────────────────────────
# Senha do usuário fintech_admin no PostgreSQL.
# Usada pelo postgres, transaction-service e account-service.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Grafana ──────────────────────────────────────────────────
# Senha do usuário admin do Grafana.
# Se não definida, o docker-compose usa "admin" como fallback (apenas dev).
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
