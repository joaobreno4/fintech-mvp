{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Throughput HTTP /transfers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10,
            "lineInterpolation": "linear", "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }]
          }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"transaction-service\",uri=\"/transfers\",status=\"201\"}[1m])",
          "legendFormat": "201 Created",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"transaction-service\",uri=\"/transfers\",status=~\"4..|5..\"}[1m])",
          "legendFormat": "4xx / 5xx Errors",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency p95 / p99 — /transfers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"transaction-service\",uri=\"/transfers\"}[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"transaction-service\",uri=\"/transfers\"}[5m]))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Memory Usage (Limite: 512MB)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      },
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "(jvm_memory_used_bytes{job=\"transaction-service\",area=\"heap\"} / jvm_memory_max_bytes{job=\"transaction-service\",area=\"heap\"}) * 100",
          "legendFormat": "Heap Usage %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM G1GC Activity",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=\"transaction-service\"}[5m])",
          "legendFormat": "GC Pauses / sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "⚠️  DEAD LETTER — Eventos Críticos Pendentes de Intervenção",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "✅  SISTEMA SAUDÁVEL", "color": "green", "index": 0 }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 1000000,
                "result": { "text": "🚨  INTERVENÇÃO NECESSÁRIA", "color": "red", "index": 1 }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "text": { "valueSize": 72, "titleSize": 16 }
      },
      "targets": [
        {
          "expr": "outbox_dead_letter_events{job=\"transaction-service\"}",
          "legendFormat": "Dead Letter Events",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Volumetria do Outbox por Status",
      "description": "Evolução temporal dos eventos no Outbox. DEAD_LETTER em vermelho indica falha de integração com Kafka.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "lineInterpolation": "stepAfter",
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "PENDING" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F5A623", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "SENT" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#37872D", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEAD_LETTER" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E02F44", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "outbox_pending_events{job=\"transaction-service\"}",
          "legendFormat": "PENDING",
          "refId": "A"
        },
        {
          "expr": "outbox_sent_events{job=\"transaction-service\"}",
          "legendFormat": "SENT",
          "refId": "B"
        },
        {
          "expr": "outbox_dead_letter_events{job=\"transaction-service\"}",
          "legendFormat": "DEAD_LETTER",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "Throughput do Relay (Kafka Producer)",
      "description": "Registros enviados ao Kafka por segundo pelo OutboxRelayService. Zero indica Kafka offline ou fila vazia.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 21 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 0.01 }
            ]
          },
          "decimals": 3
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "text": { "valueSize": 48, "titleSize": 14 }
      },
      "targets": [
        {
          "expr": "rate(kafka_producer_record_send_total{job=\"transaction-service\"}[1m])",
          "legendFormat": "Registros / seg",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fintech", "transaction-service", "outbox", "chaos-engineering"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Transaction Service — Fintech MVP",
  "uid": "transaction-service",
  "version": 2
}
